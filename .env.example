# 中标结果公示系统 环境变量配置

# 服务配置
HOST=0.0.0.0
PORT=8000
DEBUG=false

# 安全
SECRET_KEY=change-me-to-a-random-secret-key-in-production
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:5173
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# 数据库
DB_PATH=data/announcements_deep.db

# 采集数据配置
CRAWLER_RATE_LIMIT_RPM=120
CRAWLER_DEFAULT_PAGES=10

# 定时调度
SCHEDULER_ENABLED=true
SCHEDULER_INCREMENTAL_CRON=0 2 * * *
SCHEDULER_FULL_CRON=0 3 * * 0

# 通知推送
NOTIFICATION_ENABLED=false
NOTIFICATION_WEBHOOK_URL=

# AI 分析
AI_PROVIDER=
AI_API_KEY=
AI_BASE_URL=
AI_MODEL=

# 日志
LOG_LEVEL=INFO
LOG_FORMAT=json
